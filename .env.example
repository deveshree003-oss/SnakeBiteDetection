# backend/.env.example
# Copy this to backend/.env and fill in with your own values

SUPABASE_URL=https://your-project.supabase.co
# For production, use a service role key (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# or provide an anon key (writes may be blocked by RLS)
SUPABASE_ANON_KEY=your-anon-key

# Port for Express API (frontend proxy target)
PORT=5000

# AI service URL used by backend to forward images
AI_SERVICE_URL=http://localhost:8000/predict
